PAYLOAD_SECRET=replace-me-with-a-long-random-string

# Supabase: use "Connection string" → URI, port 5432 (direct) for Payload.
# Optional query: ?sslmode=require
DATABASE_URI=postgres://username:password@db.xxxxx.supabase.co:5432/postgres

# auto: cloud hosts (supabase, neon, …) use TLS. Local Postgres: set DATABASE_SSL=false
# DATABASE_SSL=true
# DATABASE_SSL=false

# Default: do not verify CA chain (fixes "self-signed certificate in chain" behind some proxies).
# Production hardening: DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

PAYLOAD_PUBLIC_CORS_URLS=http://localhost:3000

NEXT_PUBLIC_SERVER_URL=http://localhost:3000
